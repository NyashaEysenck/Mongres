# MongoDB connection used by the proxy and schema-discovery CLI.
# Docker containers reach a MongoDB running on your Mac via this hostname.
# For Atlas or another remote service, use its normal mongodb:// or mongodb+srv:// URI.
MONGO_URI=mongodb://host.docker.internal:27017
MONGO_DATABASE=my_database
# Comma-separated SQL table allowlist. It takes precedence over the legacy
# MONGO_COLLECTION setting, which remains supported for one-table deployments.
MONGO_COLLECTIONS=customers,orders
MONGO_COLLECTION=customers
MONGO_SAMPLE_SIZE=100

# PostgreSQL wire-protocol listener.
PROXY_LISTEN_ADDR=0.0.0.0:5433

# PostgreSQL startup authentication. `trust` is convenient for local development.
# `cleartext` requires both variables and should be used only over a trusted or
# TLS-protected network until SCRAM/TLS support is configured.
PROXY_AUTH_MODE=trust
PROXY_AUTH_USER=
PROXY_AUTH_PASSWORD=

# Optional constrained ambiguity resolver.
AMBIGUITY_RESOLVER_URL=http://ambiguity-resolver:8000/v1/resolve
AMBIGUITY_RESOLVER_TIMEOUT_MS=30000
AMBIGUITY_RESOLVER_MIN_CONFIDENCE=0.8

# Provider used only inside the resolver. Never commit the API key.
AMBIGUITY_LLM_PROVIDER=google
AMBIGUITY_LLM_TIMEOUT_MS=30000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# To switch providers: AMBIGUITY_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
